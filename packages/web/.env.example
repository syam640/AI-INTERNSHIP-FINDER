# ───────────────────────────────────────────────
# REQUIRED - Firebase Auth + Firestore
# ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ───────────────────────────────────────────────
# REQUIRED - Cloudinary Storage (resumes, docs)
# ───────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ───────────────────────────────────────────────
# REQUIRED - AI Provider (NVIDIA primary, OpenAI fallback)
# ───────────────────────────────────────────────
NVIDIA_API_KEY=your-nvidia-api-key
OPENAI_API_KEY=your-openai-api-key-fallback

# ───────────────────────────────────────────────
# OPTIONAL - Firebase Cloud Messaging
# ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# ───────────────────────────────────────────────
# OPTIONAL - Python Cloud Function URL (for live scraping)
# ───────────────────────────────────────────────
PYTHON_FUNCTION_URL=

# ───────────────────────────────────────────────
# OPTIONAL - Observability
# ───────────────────────────────────────────────
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_TRACING_ENABLED=false
